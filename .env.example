# Funeral Home Agent production environment template

# Server
NODE_ENV=production
PORT=3001
PUBLIC_BASE_URL=https://your-domain.com
FORCE_HTTPS=true

# Admin and service access
# Set this to a strong one-time seed password before the first production boot.
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-password
# Keep service token disabled unless you are using a trusted backend integration.
ALLOW_SERVICE_TOKEN=false
AUTH_TOKEN=

# OpenAI / AI usage controls
OPENAI_API_KEY=sk-your-openai-key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
AI_DAILY_DOCUMENT_LIMIT=100
AI_MONTHLY_DOCUMENT_HARD_LIMIT=1000

# Stripe live billing
# Use test keys while testing, then switch to live keys after Stripe account activation.
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER=price_replace_starter
STRIPE_PRICE_PROFESSIONAL=price_replace_professional
STRIPE_PRICE_ENTERPRISE=price_replace_enterprise

# Optional HTTPS certificate paths if Node terminates TLS directly.
# Most Render/Railway/Fly/AWS deployments terminate TLS at the platform/proxy instead.
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# Optional DeepSeek fallback
DEEPSEEK_API_KEY=
